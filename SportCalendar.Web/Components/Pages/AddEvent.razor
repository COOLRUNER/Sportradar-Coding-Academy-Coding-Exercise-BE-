@page "/events/add"
@using SportCalendar.Web.Models
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Add Event — SportCalendar</PageTitle>

<div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Add New Event</h1>
    <p class="text-gray-400 mb-8 text-sm">Schedule a new sports event in the calendar.</p>

    @if (!string.IsNullOrEmpty(_successMsg))
    {
        <div class="bg-emerald-900/50 border border-emerald-500 text-emerald-300 rounded-xl px-5 py-4 mb-6 flex items-center gap-3">
            <span>@_successMsg</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="bg-red-900/50 border border-red-500 text-red-300 rounded-xl px-5 py-4 mb-6 flex items-center gap-3">
            <span>@_errorMsg</span>
        </div>
    }

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-7 space-y-6">

        <div class="space-y-1.5">
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Description *</label>
            <input @bind="_description" placeholder="e.g. Champions League Final"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 text-sm focus:outline-none focus:border-emerald-500 transition-colors" />
        </div>

        <div class="space-y-1.5">
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Start Date & Time *</label>
            <input type="datetime-local" @bind="_start"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:border-emerald-500 transition-colors" />
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Sport *</label>
                <select @bind="_sportId" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-emerald-500">
                    <option value="0">-- Select Sport --</option>
                    @foreach (var s in _sports)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Venue *</label>
                <select @bind="_placeId" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-emerald-500">
                    <option value="0">-- Select Venue --</option>
                    @foreach (var p in _places)
                    {
                        <option value="@p.Id">@p.Name, @p.City</option>
                    }
                </select>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Home Team *</label>
                <select @bind="_homeTeamId" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-emerald-500">
                    <option value="0">-- Select Team --</option>
                    @foreach (var t in _teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Away Team *</label>
                <select @bind="_awayTeamId" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5 text-white text-sm focus:outline-none focus:border-emerald-500">
                    <option value="0">-- Select Team --</option>
                    @foreach (var t in _teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
        </div>

        <button @onclick="SubmitAsync" disabled="@_submitting"
                class="w-full bg-emerald-500 hover:bg-emerald-400 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-xl transition-all mt-2">
            @if (_submitting)
            {
                <span class="flex items-center justify-center gap-2">
                    <span class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                    Saving…
                </span>
            }
            else
            {
                <span>Save Event</span>
            }
        </button>
    </div>
</div>

@code {
    private string _description = "";
    private DateTime _start = DateTime.Now.AddDays(1);
    private int _sportId = 0, _placeId = 0, _homeTeamId = 0, _awayTeamId = 0;
    private bool _submitting;
    private string _successMsg = "", _errorMsg = "";

    private IEnumerable<SportDto> _sports = Enumerable.Empty<SportDto>();
    private IEnumerable<TeamDto> _teams = Enumerable.Empty<TeamDto>();
    private IEnumerable<PlaceDto> _places = Enumerable.Empty<PlaceDto>();

    protected override async Task OnInitializedAsync()
    {
        var http = HttpClientFactory.CreateClient("SportCalendarApi");
        _sports = await http.GetFromJsonAsync<IEnumerable<SportDto>>("api/sports") ?? Enumerable.Empty<SportDto>();
        _teams = await http.GetFromJsonAsync<IEnumerable<TeamDto>>("api/teams") ?? Enumerable.Empty<TeamDto>();
        _places = await http.GetFromJsonAsync<IEnumerable<PlaceDto>>("api/places") ?? Enumerable.Empty<PlaceDto>();
    }

    private async Task SubmitAsync()
    {
        _errorMsg = "";
        _successMsg = "";

        if (string.IsNullOrWhiteSpace(_description) || _sportId == 0 || _placeId == 0 || _homeTeamId == 0 || _awayTeamId == 0)
        {
            _errorMsg = "Please fill in all required fields.";
            return;
        }

        if (_homeTeamId == _awayTeamId)
        {
            _errorMsg = "Home team and away team cannot be the same.";
            return;
        }

        _submitting = true;

        try
        {
            var http = HttpClientFactory.CreateClient("SportCalendarApi");
            var payload = new
            {
                description = _description,
                start = _start,
                sportId = _sportId,
                placeId = _placeId,
                homeTeamId = _homeTeamId,
                awayTeamId = _awayTeamId
            };

            var response = await http.PostAsJsonAsync("api/events", payload);

            if (response.IsSuccessStatusCode)
            {
                _successMsg = "Event added successfully!";
                _description = "";
                _sportId = _placeId = _homeTeamId = _awayTeamId = 0;
                _start = DateTime.Now.AddDays(1);
            }
            else
            {
                _errorMsg = $"API error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Error: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
