@page "/teams/add"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Add Team — SportCalendar</PageTitle>

<div class="max-w-xl mx-auto">
    <div class="flex items-center gap-4 mb-6">
        <button @onclick="GoBack" class="text-gray-400 hover:text-white transition-colors">
            <span class="text-xl">←</span>
        </button>
        <h1 class="text-3xl font-bold">Add New Team</h1>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-7 space-y-6">
        <div class="space-y-1.5">
            <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Team Name *</label>
            <input @bind="_name" placeholder="e.g. Manchester United"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white placeholder-gray-500 text-sm focus:outline-none focus:border-emerald-500 transition-colors" />
        </div>

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="text-red-400 text-sm bg-red-900/20 border border-red-900/30 rounded-lg p-3">
                @_errorMsg
            </div>
        }

        @if (!string.IsNullOrEmpty(_successMsg))
        {
            <div class="text-emerald-400 text-sm bg-emerald-900/20 border border-emerald-900/30 rounded-lg p-3">
                @_successMsg
            </div>
        }

        <div class="pt-4 flex gap-3">
            <button @onclick="GoBack" class="flex-1 border border-gray-700 hover:border-gray-600 text-gray-300 font-semibold py-3 rounded-xl transition-all">
                Cancel
            </button>
            <button @onclick="HandleSubmit" disabled="@_submitting"
                    class="flex-[2] bg-emerald-500 hover:bg-emerald-400 disabled:opacity-50 text-white font-semibold py-3 rounded-xl transition-all shadow-lg shadow-emerald-500/20">
                @(_submitting ? "Saving..." : "Create Team")
            </button>
        </div>
    </div>
</div>

@code {
    private string _name = "";
    private bool _submitting = false;
    private string? _errorMsg;
    private string? _successMsg;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMsg = "Please enter a team name.";
            return;
        }

        _submitting = true;
        _errorMsg = null;
        _successMsg = null;

        try
        {
            var http = HttpClientFactory.CreateClient("SportCalendarApi");
            var payload = new { name = _name };
            var response = await http.PostAsJsonAsync("api/teams", payload);

            if (response.IsSuccessStatusCode)
            {
                _successMsg = "Team created successfully!";
                _name = "";
                await Task.Delay(1500);
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMsg = "Failed to create team. Ensure the name is unique.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Error: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/");
}
