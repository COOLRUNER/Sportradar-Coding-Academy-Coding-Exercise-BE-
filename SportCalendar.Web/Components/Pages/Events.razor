@page "/events"
@using SportCalendar.Web.Models
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer

<PageTitle>Events — SportCalendar</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <h1 class="text-3xl font-bold">All Events</h1>
    <a href="/events/add" class="bg-emerald-500 hover:bg-emerald-400 text-white font-semibold px-5 py-2.5 rounded-xl transition-all text-sm w-fit">
        + Add Event
    </a>
</div>

<!-- Filters -->
<div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 mb-8 flex flex-wrap gap-4 items-end">
    <div class="flex flex-col gap-1.5 flex-1 min-w-[160px]">
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Sport</label>
        <select @bind="_selectedSportId" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500">
            <option value="0">All Sports</option>
            @foreach (var sport in _sports)
            {
                <option value="@sport.Id">@sport.Name</option>
            }
        </select>
    </div>
    <div class="flex flex-col gap-1.5 flex-1 min-w-[160px]">
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Status</label>
        <select @bind="_selectedStatus" class="bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-emerald-500">
            <option value="">All Statuses</option>
            <option value="Scheduled">Scheduled</option>
            <option value="InProgress">In Progress</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>
    <button @onclick="ClearFilters" class="text-sm text-gray-400 hover:text-white transition-colors py-2 px-3 border border-gray-700 rounded-lg hover:border-gray-500">
        Clear
    </button>
</div>

@if (!string.IsNullOrEmpty(_errorMsg))
{
    <div class="bg-red-900/50 border border-red-500 text-red-300 rounded-xl px-5 py-4 mb-8 flex items-center gap-3">
        <span class="text-lg">✕</span>
        <span>@_errorMsg</span>
    </div>
}

@if (_loading)
{
    <div class="flex justify-center py-24">
        <div class="w-10 h-10 border-4 border-emerald-500 border-t-transparent rounded-full animate-spin"></div>
    </div>
}
else
{
    var filtered = FilteredEvents.ToList();

    @if (!filtered.Any())
    {
        <div class="text-center py-24 text-gray-500">
            <p>No events match your filters.</p>
        </div>
    }
    else
    {
        <p class="text-gray-500 text-sm mb-4">Showing @filtered.Count event@(filtered.Count == 1 ? "" : "s")</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var ev in filtered)
            {
                <EventCard Event="ev" />
            }
        </div>
    }
}

@code {
    private IEnumerable<EventDto> _events = Enumerable.Empty<EventDto>();
    private IEnumerable<SportDto> _sports = Enumerable.Empty<SportDto>();
    private bool _loading = true;
    private string? _errorMsg;
    private int _selectedSportId = 0;
    private string _selectedStatus = "";

    private IEnumerable<EventDto> FilteredEvents =>
        _events
            .Where(e => _selectedSportId == 0 || e.SportId == _selectedSportId)
            .Where(e => string.IsNullOrEmpty(_selectedStatus) || e.Status == _selectedStatus);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("SportCalendarApi");
            _events = await http.GetFromJsonAsync<IEnumerable<EventDto>>("api/events") ?? Enumerable.Empty<EventDto>();
            _sports = await http.GetFromJsonAsync<IEnumerable<SportDto>>("api/sports") ?? Enumerable.Empty<SportDto>();
        }
        catch (Exception ex)
        {
            _errorMsg = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ClearFilters()
    {
        _selectedSportId = 0;
        _selectedStatus = "";
    }
}
